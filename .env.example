# Database (Supabase Postgres)
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
BACKUP_DATABASE_URL="postgresql://user:password@backup-host/database?sslmode=require"

# Auth.js
# This also signs short-lived MCP OAuth consent requests. Generate a unique,
# high-entropy value for every environment; rotating it invalidates in-progress
# MCP authorizations and should be coordinated with a deploy.
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Resend (Email)
RESEND_API_KEY=""
EMAIL_DOMAIN="central.clix.co"
EMAIL_FROM="Central <noreply@central.clix.co>"

# Inngest
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Vercel Queues
# Batchable email delivery mode: inngest, shadow, or queue.
# Use shadow during observation, queue after cutover, and inngest for rollback.
EMAIL_BATCH_DELIVERY_MODE="inngest"
# Direct mention email and event-specific Slack delivery mode: inngest, shadow, or queue.
NOTIFICATION_DELIVERY_MODE="inngest"
# Scheduled background jobs delivery mode: inngest, shadow, or queue.
BACKGROUND_JOB_DELIVERY_MODE="inngest"
# Recurring next-task creation mode: inngest, shadow, or queue.
RECURRING_TASK_DELIVERY_MODE="inngest"
# Legacy pilot fallback. If EMAIL_BATCH_DELIVERY_MODE is unset, true behaves like shadow.
EMAIL_QUEUE_PILOT_ENABLED="false"
# Required for local/non-Vercel Queue access. Vercel deployments use OIDC automatically.
VERCEL_QUEUE_API_TOKEN=""

# Slack
SLACK_BOT_TOKEN=""
# Slack Workspace/Team ID (starts with T) — used for desktop app deep links
NEXT_PUBLIC_SLACK_WORKSPACE_ID=""

# Supabase (Realtime only — used for live cache invalidation)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# App
# Public, canonical HTTPS origin. The MCP OAuth issuer, resource metadata, and
# Claude callback flow derive their URLs from this value; it must not be a
# preview, localhost, or internal-only URL in a deployed environment.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CRON_SECRET=""
